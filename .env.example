# Server
PORT=5000

# Sequelize schema sync: keep false (default). alter=true can duplicate indexes on basic_user.
# DB_SYNC_ALTER=false

# MySQL (create database manually, e.g. CREATE DATABASE musyamatch;)
DB_HOST=localhost
# Use the same port as in MySQL Workbench (often 3306; XAMPP/custom installs may use 3307).
DB_PORT=3306
DB_NAME=musyamatch
DB_USER=root
DB_PASSWORD=

# AI chat (Musya expert) — use OpenAI OR local Ollama (see services/aiChat.js)
# If OPENAI_API_KEY or AI_API_KEY is set, OpenAI is used. Otherwise Ollama at OLLAMA_HOST.
OPENAI_API_KEY=
AI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
