{
  "name": "musyamatch-backend",
  "version": "1.0.0",
  "description": "MusyaMatch API (Express + Sequelize + MySQL)",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "build": "npm run build --prefix client",
    "postinstall": "npm install --prefix client",
    "client:build": "npm run build --prefix client",
    "db:add-need-due-date": "node scripts/add-shelter-need-due-date.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "sequelize": "^6.37.3"
  }
}
